+++ b/core/gsmp.py
@@ -0,0 +1,208 @@
+"""GSMP edge-weight preprocessing for DGL/PyTorch edge-index graphs.
+
+The message-passing convention is source -> destination.  For each edge
+``src -> dst``, the timestamp used by GSMP is ``node_year[src]``.
+"""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+from typing import Dict, Optional, Tuple
+
+import torch
+
+
+SUPPORTED_MODES = {"strict", "scale_preserve"}
+
+
+def _as_cpu_long(tensor: torch.Tensor, name: str) -> torch.Tensor:
+    if not torch.is_tensor(tensor):
+        raise TypeError(f"{name} must be a torch.Tensor")
+    return tensor.detach().cpu().long()
+
+
+def _stats(weight: torch.Tensor, node_year: torch.Tensor) -> Dict[str, float | int]:
+    weight_float = weight.detach().cpu().float()
+    return {
+        "num_edges": int(weight_float.numel()),
+        "num_unique_years": int(torch.unique(node_year.detach().cpu().long()).numel()),
+        "min": float(weight_float.min().item()) if weight_float.numel() else 0.0,
+        "max": float(weight_float.max().item()) if weight_float.numel() else 0.0,
+        "mean": float(weight_float.mean().item()) if weight_float.numel() else 0.0,
+        "std": float(weight_float.std(unbiased=False).item()) if weight_float.numel() else 0.0,
+    }
+
+
+def compute_gsmp_edge_weight(
+    edge_index: torch.Tensor,
+    node_year: torch.Tensor,
+    num_nodes: int,
+    mode: str = "scale_preserve",
+    device: Optional[torch.device | str] = None,
+) -> torch.Tensor:
+    """Compute GSMP weights for directed edges.
+
+    Args:
+        edge_index: Tensor with shape [2, num_edges], where row 0 is source
+            node IDs and row 1 is destination node IDs.
+        node_year: Tensor with one publication year per node.
+        num_nodes: Number of graph nodes.
+        mode: ``strict`` or ``scale_preserve``.
+        device: Optional output device. Computation itself stays on CPU.
+
+    ``strict`` returns the empirical GSMP aggregation weight:
+
+        1 / (num_unique_neighbor_times[dst] * count[dst, node_year[src]])
+
+    ``scale_preserve`` returns the GSMP scale factor:
+
+        (1 / count[dst, node_year[src]]) / mean_base_for_target[dst]
+
+    The caller should multiply the ``scale_preserve`` output by the layer's
+    ordinary aggregation normalization, for example ``1 / in_degree[dst]``.
+    """
+
+    if mode not in SUPPORTED_MODES:
+        raise ValueError(f"Unsupported GSMP mode {mode!r}; choose one of {sorted(SUPPORTED_MODES)}")
+    edge_index = _as_cpu_long(edge_index, "edge_index")
+    node_year = _as_cpu_long(node_year, "node_year").view(-1)
+    if edge_index.dim() != 2 or edge_index.size(0) != 2:
+        raise ValueError("edge_index must have shape [2, num_edges]")
+    if node_year.numel() < num_nodes:
+        raise ValueError(f"node_year has {node_year.numel()} values for num_nodes={num_nodes}")
+
+    src, dst = edge_index[0], edge_index[1]
+    if src.numel() == 0:
+        return torch.empty(0, dtype=torch.float32, device=device)
+    if int(src.max().item()) >= num_nodes or int(dst.max().item()) >= num_nodes:
+        raise ValueError("edge_index contains node IDs >= num_nodes")
+    if int(src.min().item()) < 0 or int(dst.min().item()) < 0:
+        raise ValueError("edge_index contains negative node IDs")
+
+    _, year_id = torch.unique(node_year[:num_nodes], sorted=True, return_inverse=True)
+    num_years = int(year_id.max().item()) + 1 if year_id.numel() else 0
+    edge_year_id = year_id[src]
+
+    key = dst * num_years + edge_year_id
+    counts = torch.bincount(key, minlength=num_nodes * num_years).float()
+    edge_counts = counts[key].clamp_min(1.0)
+    base = 1.0 / edge_counts
+
+    if mode == "strict":
+        present = counts.view(num_nodes, num_years) > 0
+        num_present_years = present.sum(dim=1).float().clamp_min(1.0)
+        weight = base / num_present_years[dst]
+    else:
+        sum_base_per_dst = torch.zeros(num_nodes, dtype=torch.float32)
+        sum_base_per_dst.scatter_add_(0, dst, base)
+        deg = torch.bincount(dst, minlength=num_nodes).float().clamp_min(1.0)
+        mean_base = sum_base_per_dst / deg
+        weight = base / mean_base[dst].clamp_min(1e-12)
+
+    if not torch.isfinite(weight).all():
+        raise FloatingPointError("GSMP edge weights contain NaN or Inf")
+    return weight.to(device=device, dtype=torch.float32)
+
+
+def compute_mean_edge_weight(edge_index: torch.Tensor, num_nodes: int, device: Optional[torch.device | str] = None) -> torch.Tensor:
+    """Return ordinary incoming mean aggregation weights, 1 / in_degree[dst]."""
+
+    edge_index = _as_cpu_long(edge_index, "edge_index")
+    dst = edge_index[1]
+    if dst.numel() == 0:
+        return torch.empty(0, dtype=torch.float32, device=device)
+    deg = torch.bincount(dst, minlength=num_nodes).float().clamp_min(1.0)
+    weight = 1.0 / deg[dst]
+    if not torch.isfinite(weight).all():
+        raise FloatingPointError("Mean edge weights contain NaN or Inf")
+    return weight.to(device=device, dtype=torch.float32)
+
+
+def build_linear_message_weight(
+    edge_index: torch.Tensor,
+    node_year: torch.Tensor,
+    num_nodes: int,
+    use_gsmp: bool,
+    mode: str = "scale_preserve",
+    device: Optional[torch.device | str] = None,
+) -> Tuple[torch.Tensor, Dict[str, float | int | str | bool]]:
+    """Build the final message weight consumed by LinearRevGAT.
+
+    Without GSMP this returns ordinary mean aggregation weights.
+
+    With ``mode='strict'`` this returns strict GSMP weights directly.
+
+    With ``mode='scale_preserve'`` this returns ``mean_weight * gsmp_scale``.
+    This keeps target-level aggregation magnitude comparable to mean
+    aggregation while still reweighting neighbor-year groups by inverse
+    frequency.
+    """
+
+    cpu_edge_index = _as_cpu_long(edge_index, "edge_index")
+    cpu_year = _as_cpu_long(node_year, "node_year").view(-1)
+    mean_weight = compute_mean_edge_weight(cpu_edge_index, num_nodes)
+    if use_gsmp:
+        gsmp_weight = compute_gsmp_edge_weight(cpu_edge_index, cpu_year, num_nodes, mode=mode)
+        final_weight = gsmp_weight if mode == "strict" else mean_weight * gsmp_weight
+    else:
+        final_weight = mean_weight
+
+    if not torch.isfinite(final_weight).all():
+        raise FloatingPointError("Final message weights contain NaN or Inf")
+    stats = _stats(final_weight, cpu_year)
+    stats.update(
+        {
+            "use_gsmp": bool(use_gsmp),
+            "mode": mode,
+            "weight_semantics": "strict_gsmp" if use_gsmp and mode == "strict" else "mean_times_gsmp_scale" if use_gsmp else "incoming_mean",
+        }
+    )
+    print("[GSMP_STATS] " + json.dumps(stats, sort_keys=True), flush=True)
+    return final_weight.to(device=device, dtype=torch.float32), stats
+
+
+def cached_linear_message_weight(
+    edge_index: torch.Tensor,
+    node_year: torch.Tensor,
+    num_nodes: int,
+    use_gsmp: bool,
+    mode: str,
+    cache_dir: str | Path,
+    dataset: str,
+    graph_direction: str,
+    feature_type: str,
+    device: Optional[torch.device | str] = None,
+) -> Tuple[torch.Tensor, Dict[str, float | int | str | bool]]:
+    """Load or compute final LinearRevGAT message weights.
+
+    The cache key includes dataset, graph direction, feature type, and GSMP
+    mode so smoke/full runs reuse the same CPU preprocessing result.
+    """
+
+    cache_dir = Path(cache_dir)
+    cache_dir.mkdir(parents=True, exist_ok=True)
+    variant = "gsmp" if use_gsmp else "mean"
+    safe_feature = feature_type.replace("/", "_")
+    cache_path = cache_dir / f"{dataset}_{graph_direction}_{safe_feature}_{variant}_{mode}_linear_weight.pt"
+    if cache_path.exists():
+        payload = torch.load(cache_path, map_location="cpu")
+        weight = payload["weight"].float()
+        stats = payload.get("stats", {})
+        if not torch.isfinite(weight).all():
+            raise FloatingPointError(f"Cached weights contain NaN or Inf: {cache_path}")
+        print(f"[GSMP_CACHE] loaded {cache_path}", flush=True)
+        print("[GSMP_STATS] " + json.dumps(stats, sort_keys=True), flush=True)
+        return weight.to(device=device, dtype=torch.float32), stats
+
+    weight, stats = build_linear_message_weight(
+        edge_index=edge_index,
+        node_year=node_year,
+        num_nodes=num_nodes,
+        use_gsmp=use_gsmp,
+        mode=mode,
+        device=None,
+    )
+    torch.save({"weight": weight.cpu(), "stats": stats}, cache_path)
+    print(f"[GSMP_CACHE] saved {cache_path}", flush=True)
+    return weight.to(device=device, dtype=torch.float32), stats
